# Шаблон переменных для внешних футбольных API.
# Скопируйте как local.env в эту же папку и добавьте в pubspec.yaml → assets (см. README).
#
# API-Football (api-sports.io): https://www.api-football.com/
API_FOOTBALL_KEY=
# ID лиг через запятую (39 = Premier League, 235 = РПЛ и т.д.)
API_FOOTBALL_LEAGUE_IDS=39,235
#
# football-data.org: https://www.football-data.org/
FOOTBALL_DATA_TOKEN=

# (опционально) Unsplash API для фото стадионов.
# Получить ключ: https://unsplash.com/developers
